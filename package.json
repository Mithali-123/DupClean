{
  "name": "dupclean-pro",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.moseskenny.dupclean",
    "productName": "DupClean Pro",
    "directories": {
      "output": "release"
    },
    "files": [
      "frontend/dist/**/*",
      "main.js"
    ],
    "extraResources": [
      {
        "from": "backend/dist/app.exe",
        "to": "backend/app.exe"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}